# SharePoint- Partage de Fichiers Zero-Trust (E2EE)
Application sécurisée garantissant que le serveur ne voit jamais les fichiers ni les clés en clair.

## Prérequis et Installation
1. Installez Node.js et PostgreSQL sur votre machine.
2. Ouvrez un terminal dans le dossier et exécutez : npm install ou npm i
3. Créez un fichier `.env` à la racine avec vos identifiants :
   PORT=3000
   DB_USER=postgres
   DB_PASSWORD=votre_mot_de_passe
   DB_HOST=localhost
   DB_NAME=sharelock_db
   SESSION_SECRET=phrase_aleatoire_tres_longue_de_votre_choix

## Base de données
Exécutez ce script SQL pour générer l'architecture de chiffrement :

```sql
DROP TABLE IF EXISTS partages_fichiers CASCADE;
DROP TABLE IF EXISTS fichiers CASCADE;
DROP TABLE IF EXISTS utilisateurs CASCADE;

CREATE TABLE utilisateurs (
    id SERIAL PRIMARY KEY,
    nom_utilisateur VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(255) NOT NULL UNIQUE,
    mot_de_passe_hash VARCHAR(255) NOT NULL,
    cle_publique TEXT NOT NULL,
    cle_privee_chiffree TEXT NOT NULL,
    sel_crypto VARCHAR(64) NOT NULL,
    iv_crypto VARCHAR(64) NOT NULL,
    encrypted_private_key_backup TEXT NULL,
    date_creation TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_email_format CHECK (email ~* '^[A-Za-z0-9._+%-]+@[A-Za-z0-9.-]+[.][A-Za-z]+$'),
    CONSTRAINT chk_nom_longueur CHECK (length(nom_utilisateur) >= 3)
);

CREATE TABLE fichiers (
    id SERIAL PRIMARY KEY,
    proprietaire_id INTEGER NOT NULL REFERENCES utilisateurs(id) ON DELETE CASCADE,
    nom_fichier TEXT NOT NULL, -- Changé en TEXT pour supporter le nom chiffré + IV
    chemin_stockage VARCHAR(500) NOT NULL,
    taille_octets BIGINT NOT NULL,
    cle_aes_chiffree TEXT NOT NULL,
    iv_fichier VARCHAR(64) NOT NULL,
    date_upload TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_taille_positive CHECK (taille_octets >= 0)
);

CREATE TABLE partages_fichiers (
    id SERIAL PRIMARY KEY,
    fichier_id INTEGER NOT NULL REFERENCES fichiers(id) ON DELETE CASCADE,
    destinataire_id INTEGER NOT NULL REFERENCES utilisateurs(id) ON DELETE CASCADE,
    cle_aes_partagee TEXT NOT NULL,
    date_partage TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT unq_fichier_destinataire UNIQUE (fichier_id, destinataire_id)
);

-- Les index pour optimiser la vitesse de recherche de ton serveur
CREATE INDEX idx_partages_destinataire ON partages_fichiers(destinataire_id);
CREATE INDEX idx_utilisateurs_nom ON utilisateurs(nom_utilisateur);
CREATE INDEX idx_utilisateurs_email ON utilisateurs(email);
CREATE INDEX idx_fichiers_proprietaire ON fichiers(proprietaire_id);