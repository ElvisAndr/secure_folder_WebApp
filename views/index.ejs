<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Mes Fichiers Sécurisés (E2EE)</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="css/index.css">
    <script src="/js/cryptoDB.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
</head>

<body style="margin: 0; padding: 40px 20px; background-color: var(--bg-base); display: block;">

    <!-- Barre de navigation -->
    <nav class="navbar">
        <div class="logo-container" style="margin-bottom: 0;">
            <img src="/images/logo_white.png" alt="ShareLock">
        </div>
        <a href="#" onclick="secureLogout()" style="color: var(--accent-red); font-weight: 600; font-size: 0.95rem;">
            Déconnexion
        </a>
    </nav>

    <div class="dashboard-container">

        <!-- Section pour téléverser un fichier -->
        <div class="upload-box">
            <h3 style="margin-top: 0; color: #fff;">Sécuriser un nouveau fichier</h3>
            <p style="margin-bottom: 20px;">Le chiffrement s'effectue localement avant l'envoi.</p>

            <form id="upload-form"
                style="max-width: 400px; margin: 0 auto; display: flex; flex-direction: column; gap: 15px;">

                <div class="file-input-wrapper">
                    <input type="file" id="file-input" required>

                    <label for="file-input" class="file-label" id="file-dropzone">
                        <img src="/images/add_file.svg" alt="" style="width: 40px; margin-bottom: 10px;">
                        <span id="file-name-display">Cliquez pour sélectionner un fichier</span>
                    </label>
                </div>

                <button type="submit" id="upload-btn">
                    Téléverser en toute sécurité
                </button>
            </form>
            <p id="upload-status"></p>
        </div>

        <hr>

        <!-- Liste des fichiers personnels -->
        <h3>Mes Fichiers Personnels</h3>
        <div class="file-list">
            <% if (typeof fichiers !=='undefined' && fichiers.length> 0) { %>
                <% fichiers.forEach(function(fichier) { %>
                    <div class="file-item">
                        <span>
                            <img src="/images/file.svg" alt=""
                                style="width: 20px; vertical-align: middle; margin-right: 8px;">
                            <%= fichier.nom_fichier %>
                        </span>
                        <div>
                            <button onclick="downloadFile('/download/<%= fichier.id %>')">Télécharger</button>

                            <button class="share-btn" data-id="<%= fichier.id %>" data-name="<%= fichier.nom_fichier %>"
                                data-key="<%= fichier.cle_aes_chiffree %>"
                                onclick="openSharePanel(this)">Partager</button>

                            <button onclick="confirmDeleteFile('<%= fichier.id %>', '<%= fichier.nom_fichier %>')"
                                style="background-color: #dc3545; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-left: 5px;"
                                onmouseover="this.style.backgroundColor='#a71d2a'"
                                onmouseout="this.style.backgroundColor='#dc3545'"
                                title="Supprimer définitivement ce fichier">
                                Supprimer
                            </button>
                        </div>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <p style="text-align: center; padding: 20px;">Aucun fichier stocké pour le moment.</p>
                            <% } %>
        </div>

        <!-- Liste des fichiers partagés -->
        <h3 style="margin-top: 30px;">Fichiers partagés avec moi</h3>
        <div class="file-list">
            <% if (typeof fichiersPartages !=='undefined' && fichiersPartages.length> 0) { %>
                <% fichiersPartages.forEach(function(partage) { %>
                    <div class="file-item shared-with-me">
                        <span>
                            <img src="/images/file_shared.svg" alt=""
                                style="width: 25px; vertical-align: middle; margin-right: 8px;">
                            <%= partage.nom_fichier %> <small>(de <%= partage.proprietaire %>)</small>
                        </span>
                        <div>
                            <button
                                onclick="downloadFile('/download-shared/<%= partage.partage_id %>')">Télécharger</button>
                        </div>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <p style="text-align: center; padding: 20px;">Aucun fichier partagé avec vous pour le
                                moment.</p>
                            <% } %>
        </div>
    </div>

    <!-- Panneau de partage -->
    <div id="share-panel" class="share-panel">
        <div class="share-panel-content">

            <button class="close-btn" type="button" onclick="closeSharePanel()">✕ Fermer</button>

            <h2 style="color: #fff; margin-bottom: 5px; font-size: 2.2rem;">Partager</h2>
            <p style="margin-bottom: 25px; color: var(--text-muted);">
                Fichier : <strong id="share-filename" style="color: var(--accent-blue);"></strong>
            </p>

            <form id="share-form">
                <input type="hidden" id="share-file-id">
                <input type="hidden" id="share-encrypted-aes">

                <input type="text" id="share-recipient" placeholder="Nom d'utilisateur du contact" required
                    autocomplete="off">

                <button type="submit" class="share-btn">
                    Partager en toute sécurité
                </button>
            </form>

            <p id="share-status"></p>

        </div>
    </div>
    <script>
        window.MA_CLE_PUBLIQUE = "<%= publicKey %>";
    </script>
    <script src="js/index.js" defer></script>
</body>

</html>