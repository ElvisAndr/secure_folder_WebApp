<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <title>Connexion E2EE - ShareLock</title>
    <link rel="stylesheet" href="css/style.css">
    <script src="/js/cryptoDB.js"></script>
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
</head>

<body style="margin: 0; padding: 0; background-color: #000000;">

    <!-- Wrapper principal pour la connexion -->
    <div class="auth-wrapper">

        <!-- Section gauche avec le logo et le slogan -->
        <div class="auth-left">
            <div class="brand-section">
                <h1 class="welcome-text">Bienvenue sur</h1>
                <div class="logo-container">
                    <img src="/images/logo.png" alt="ShareLock">
                </div>
                <p class="tagline">L'architecture Zero-Trust qui protège vos données de bout en bout.</p>
            </div>
        </div>

        <!-- Section droite avec le formulaire de connexion -->
        <div class="auth-right">
            <div class="auth-form-container">
                <h2 class="title_header">Connexion</h2>

                <!-- Formulaire de connexion -->
                <form id="login-form">
                    <input type="text" id="username" placeholder="Nom d'utilisateur" required autocomplete="off">
                    <input type="password" id="password" placeholder="Mot de passe" required>

                    <button type="submit" id="submit-btn">
                        Se connecter
                    </button>
                </form>

                <!-- Lien vers la page d'inscription -->
                <div class="auth-footer">
                    <p>Pas encore de compte ? <a href="/register">S'inscrire</a></p>
                </div>

                <p id="status-message"></p>
            </div>
        </div>
    </div>
    <script src="js/login.js" defer></script>
</body>

</html>